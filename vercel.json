{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "static/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/api/webhook", "dest": "/api/webhook" },
    { "src": "/(.*)", "dest": "api/webhook.py" }
  ]
}